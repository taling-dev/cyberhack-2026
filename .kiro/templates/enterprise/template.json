{
  "name": "enterprise",
  "description": "Enterprise DaaS application with advanced features",
  "features": [
    "auth",
    "rbac",
    "collections",
    "relations",
    "files",
    "crud",
    "workflow",
    "versioning",
    "audit",
    "multi-tenant"
  ],
  "architecture": {
    "description": "Two-tier architecture: Frontend connects to DaaS backend, NOT directly to Supabase",
    "frontend": "This app - Full admin UI with workflows, permissions, and audit trails",
    "backend": "DaaS - DaaS-compatible API server",
    "database": "Supabase PostgreSQL (accessed via DaaS backend)"
  },
  "environment": {
    "required": [
      {
        "name": "NEXT_PUBLIC_SUPABASE_URL",
        "description": "Supabase project URL (for auth)"
      },
      {
        "name": "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "description": "Supabase anon key (for auth)"
      },
      {
        "name": "NEXT_PUBLIC_BUILDPAD_DAAS_URL",
        "description": "DaaS backend URL (e.g., http://localhost:3000)"
      }
    ],
    "optional": [
      {
        "name": "NEXT_PUBLIC_APP_NAME",
        "description": "Application display name"
      },
      {
        "name": "MAX_BATCH_MUTATION",
        "description": "Maximum batch mutations (default: 100)"
      },
      {
        "name": "AUDIT_LOG_RETENTION_DAYS",
        "description": "Days to retain audit logs"
      },
      {
        "name": "WORKFLOW_TIMEOUT_MS",
        "description": "Workflow step timeout in ms"
      }
    ]
  },
  "structure": {
    "directories": [
      "app/api/items/[collection]",
      "app/api/items/[collection]/[id]",
      "app/api/collections",
      "app/api/fields/[collection]",
      "app/api/relations",
      "app/api/files",
      "app/api/auth",
      "app/api/users",
      "app/api/roles",
      "app/api/permissions",
      "app/api/workflows",
      "app/api/versions",
      "app/api/audit",
      "app/(dashboard)",
      "app/(dashboard)/[collection]",
      "app/(dashboard)/[collection]/[id]",
      "app/(dashboard)/settings",
      "app/(dashboard)/admin",
      "app/(dashboard)/admin/users",
      "app/(dashboard)/admin/roles",
      "app/(dashboard)/admin/workflows",
      "components/ui",
      "components/layout",
      "components/workflow",
      "lib/supabase",
      "lib/buildpad",
      "supabase/migrations",
      "tests",
      "tests/e2e",
      "tests/load"
    ],
    "note": "Directories are hints for agents. Actual files come from CLI."
  },
  "dependencies": {
    "production": [
      "@mantine/core@^8.0.0",
      "@mantine/hooks@^8.0.0",
      "@mantine/form@^8.0.0",
      "@mantine/notifications@^8.0.0",
      "@mantine/modals@^8.0.0",
      "@mantine/dates@^8.0.0",
      "@mantine/dropzone@^8.0.0",
      "@mantine/tiptap@^8.0.0",
      "@tiptap/react@^2.0.0",
      "@tiptap/starter-kit@^2.0.0",
      "@supabase/supabase-js@^2.0.0",
      "@supabase/ssr@^0.5.0",
      "@tabler/icons-react@^3.0.0",
      "@tanstack/react-query@^5.0.0",
      "zod@^3.0.0",
      "dayjs@^1.0.0"
    ],
    "development": [
      "@types/node",
      "@types/react",
      "@types/react-dom",
      "typescript",
      "eslint",
      "eslint-config-next",
      "@playwright/test",
      "vitest",
      "@testing-library/react",
      "k6"
    ]
  },
  "prerequisites": {
    "description": "Required tools that must be installed before project creation",
    "check": "node --version && pnpm --version && git --version && npx --version",
    "required": [
      {
        "name": "Node.js",
        "minVersion": "24",
        "check": "node --version",
        "officialGuide": "https://nodejs.org/en/download",
        "install": {
          "macos": "brew install node@24",
          "macos-alt": "brew install fnm && fnm install 24",
          "linux": "curl -fsSL https://fnm.vercel.app/install | bash && fnm install 24",
          "windows": "winget install OpenJS.NodeJS.LTS",
          "windows-alt": "Download from https://nodejs.org/en/download"
        }
      },
      {
        "name": "pnpm",
        "minVersion": "10",
        "check": "pnpm --version",
        "officialGuide": "https://pnpm.io/installation",
        "install": {
          "all": "corepack enable && corepack prepare pnpm@latest --activate",
          "fallback": "npm install -g pnpm"
        }
      },
      {
        "name": "Git",
        "minVersion": "2.30",
        "check": "git --version",
        "install": {
          "macos": "xcode-select --install",
          "linux": "sudo apt-get install -y git"
        }
      }
    ]
  },
  "buildpad": {
    "description": "Components distributed via buildpad-ui CLI (Copy & Own model)",
    "repository": "buildpad-ui",
    "installation": {
      "prerequisite": "node --version && pnpm --version && git --version (install missing tools first)",
      "recommended": "npx @buildpad/cli@latest bootstrap --cwd /path/to/project",
      "step1": "cd /path/to/buildpad-ui && pnpm install && pnpm build",
      "step2": "pnpm cli init --cwd /path/to/project",
      "step3": "pnpm cli add --all --cwd /path/to/project",
      "step4": "pnpm cli validate --cwd /path/to/project"
    },
    "documentation": {
      "cli": "buildpad-ui/docs/CLI.md",
      "architecture": "buildpad-ui/docs/ARCHITECTURE.md",
      "componentMap": "buildpad-ui/docs/COMPONENT_MAP.md",
      "testing": "buildpad-ui/docs/TESTING.md"
    },
    "targetDirectories": {
      "components": "components/ui/",
      "libs": "lib/buildpad/"
    },
    "tracking": "buildpad.json",
    "autoGenerated": {
      "description": "CLI auto-generates these files to prevent common errors:",
      "files": [
        "components/ui/index.ts - exports all installed components",
        "lib/buildpad/common-utils.ts - renamed from utils.ts to avoid path collision",
        "types/modules.d.ts - TypeScript declarations for EditorJS, MapLibre, etc."
      ]
    },
    "transformations": {
      "description": "CLI automatically handles these import transformations:",
      "patterns": [
        "@buildpad/types → @/lib/buildpad/types",
        "@buildpad/services → @/lib/buildpad/services",
        "@buildpad/hooks → @/lib/buildpad/hooks",
        "../upload → ./upload (relative imports flattened)"
      ]
    }
  },
  "copilotInstructions": {
    "projectType": "enterprise",
    "criticalRules": [
      "🔴 CLI-FIRST: Use buildpad-ui CLI for all component installation",
      "🔴 NO CODE TEMPLATES: Do not use template files - CLI generates all code",
      "🔴 BUILDPAD-FIRST: All UI uses Buildpad components from @/components/ui",
      "PHASED-DEVELOPMENT: Build in phases (0-5), never all at once",
      "TESTS-REQUIRED: Every implementation must have corresponding tests",
      "AUDIT-TRAIL: All data changes must be logged"
    ],
    "features": [
      "Full CRUD operations",
      "Role-based access control",
      "File management",
      "Relational data (M2M, M2O, O2M, M2A)",
      "Dynamic forms and lists",
      "Workflow state machines",
      "Content versioning",
      "Audit logging",
      "Multi-tenant support"
    ],
    "customAllowed": [
      "App-specific layouts (navigation, sidebars)",
      "Custom dashboards and visualizations",
      "Workflow visualizations",
      "Composite components combining Buildpad components"
    ],
    "customForbidden": [
      "Input/text components - use Input, Textarea from CLI",
      "Select/dropdown components - use SelectDropdown from CLI",
      "Date/time pickers - use DateTime from CLI",
      "File upload components - use FileInterface, Files from CLI",
      "Relation selectors - use ListM2M, ListM2O, ListO2M, ListM2A from CLI"
    ]
  }
}