{
  "realm": "simaops",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "sslRequired": "external",

  "ssoSessionMaxLifespan": 259200,
  "ssoSessionIdleTimeout": 86400,
  "accessTokenLifespan": 300,
  "revokeRefreshToken": true,
  "refreshTokenMaxReuse": 3,
  "offlineSessionIdleTimeout": 2592000,
  "roles": {
    "realm": [
      { "name": "OPERATOR", "description": "Lot intake and QC image upload" },
      { "name": "QC_SUPERVISOR", "description": "Approve/reject QC results" },
      { "name": "WAREHOUSE_STAFF", "description": "Assign warehouse slots" },
      { "name": "MANAGER", "description": "View dashboards and audit logs" },
      { "name": "ADMIN", "description": "Full system access" }
    ]
  },
  "clients": [
    {
      "clientId": "simaops-web",
      "name": "SimaOps Web BFF",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:3000/*",
        "https://*.example.com/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:3000",
        "https://*.example.com"
      ],
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "defaultClientScopes": ["openid", "profile", "email", "roles"]
    },
    {
      "clientId": "simaops-api",
      "name": "SimaOps API service account",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "secret": "${SIMAOPS_API_CLIENT_SECRET}",
      "protocol": "openid-connect",
      "serviceAccountClientRoles": {
        "realm-management": ["manage-users", "view-users", "view-realm", "manage-realm"]
      }
    }
  ],
  "clientScopes": [
    {
      "name": "roles",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true" },
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "operator",
      "email": "operator@simaops.local",
      "firstName": "Budi",
      "lastName": "Operator",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "${SIMAOPS_SEED_OPERATOR_PASSWORD}", "temporary": true }],
      "realmRoles": ["OPERATOR"]
    },
    {
      "username": "qc_supervisor",
      "email": "qc@simaops.local",
      "firstName": "Siti",
      "lastName": "QC Supervisor",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "${SIMAOPS_SEED_QC_PASSWORD}", "temporary": true }],
      "realmRoles": ["QC_SUPERVISOR"]
    },
    {
      "username": "warehouse",
      "email": "warehouse@simaops.local",
      "firstName": "Agus",
      "lastName": "Warehouse",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "${SIMAOPS_SEED_WAREHOUSE_PASSWORD}", "temporary": true }],
      "realmRoles": ["WAREHOUSE_STAFF"]
    },
    {
      "username": "manager",
      "email": "manager@simaops.local",
      "firstName": "Dewi",
      "lastName": "Manager",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "${SIMAOPS_SEED_MANAGER_PASSWORD}", "temporary": true }],
      "realmRoles": ["MANAGER"]
    },
    {
      "username": "admin",
      "email": "admin@simaops.local",
      "firstName": "Andi",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "${SIMAOPS_SEED_ADMIN_PASSWORD}", "temporary": true }],
      "realmRoles": ["ADMIN"]
    }
  ]
}
