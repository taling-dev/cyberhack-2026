# SimaOps API — local development environment
PORT=8080

# TiDB
TIDB_DSN=root:@tcp(localhost:4000)/simaops?parseTime=true

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=simaops
MINIO_SECRET_KEY=simaops-dev-secret
MINIO_USE_SSL=false

# NATS
NATS_URL=nats://localhost:4222

# Keycloak
KEYCLOAK_ISSUER=http://localhost:8080/realms/simaops
KEYCLOAK_CLIENT_ID=simaops-web

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=simaops-api
